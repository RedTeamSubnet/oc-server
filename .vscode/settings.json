{
	"workbench.iconTheme": "material-icon-theme",
	"workbench.editor.highlightModifiedTabs": true,
	"explorer.autoReveal": false,
	"git.autofetch": true,
	"git.autofetchPeriod": 120,
	"diffEditor.ignoreTrimWhitespace": false,
	"editor.fontWeight": "500",
	"editor.renderWhitespace": "all",
	"editor.rulers": [
		120
	],
	"editor.smoothScrolling": true,
	"editor.detectIndentation": false,
	"editor.insertSpaces": false,
	"editor.tabSize": 4,
	"[markdown]": {
		"editor.insertSpaces": true,
		"files.trimTrailingWhitespace": false
	},
	"[yaml]": {
		"editor.formatOnSave": false,
		"editor.insertSpaces": true,
		"editor.tabSize": 2
	},
	"[json][jsonc]": {
		"editor.formatOnSave": true
	},
	"[toml]": {
		"editor.formatOnSave": false
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.formatOnSave": true
	},
	"files.eol": "\n",
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true,
	"files.associations": {
		"*.env": "dotenv",
		"*.env.*": "dotenv",
		"*.json": "jsonc",
		"*.json.example": "jsonc",
		"*.json.bak": "jsonc",
		"*.yml.bak": "yaml",
		"*.yaml.bak": "yaml",
		".gitignore": "ignore",
		".dockerignore": "ignore",
		"*Dockerfile*": "dockerfile",
	},
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/.hg/store/**": true,
		"**/.vscode-server/**": true,
		"**/.idea/**": true,
		"**/.ipynb_checkpoints/**": true,
		"**/.pytest_cache/**": true,
		"**/.benchmarks/**": true,
		"**/__pycache__/**": true,
		"**/CVS/**": true,
		"**/node_modules/*/**": true,
		"**/bower_components/**": true,
		"**/dist/**": true,
		"**/build/**": true,
		"**/.turbo/**": true,
		"**/log/**": true,
		"**/logs/**": true,
		"**/tmp/**": true,
		"**/*.log": true,
		"**/*.out": true,
		"**/*.bak": true,
		"**/.DS_Store": true,
		"**/Thumbs.db": true
	},
	"files.exclude": {
		"**/.git": false,
		"**/.svn": false,
		"**/.hg": false,
		"**/CVS": false,
		"**/.DS_Store": false,
		"**/Thumbs.db": false
	},
	"search.showLineNumbers": true,
	"search.useIgnoreFiles": false,
	"search.exclude": {
		"**/*.code-search": true,
		"**/.git": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/.vscode": true,
		"**/.vscode-server": true,
		"**/.idea": true,
		"**/node_modules": true,
		"**/dist": true,
		"**/build": true,
		"**/.turbo": true,
		"**/log": true,
		"**/logs": true,
		"**/tmp": true,
		"**/*.log": true,
		"**/*.out": true,
		"**/*.bak": true,
		"**/.DS_Store": true,
		"**/Thumbs.db": true,
	}
}
